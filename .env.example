# Public URL of the app (used for absolute OG image URLs, etc.)
APP_URL=https://cozy-corner.fly.dev

# AT Protocol service DID for authentication
SERVICE_DID=did:web:cozy-corner.fly.dev

# PDS URL for the /pds proxy and server-side handle/record resolution.
# In production this is typically not needed (uses public PLC directory).
# For local development with a local PDS, set this to the PDS origin:
# PDS_URL=http://localhost:2583
